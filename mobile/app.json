{
  "expo": {
    "name": "FoodLog",
    "slug": "food-log",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "foodlog",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.foodlog.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow FoodLog to access your camera to photograph food for calorie tracking.",
        "NSPhotoLibraryUsageDescription": "Allow FoodLog to access your photo library to select food photos for tracking."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      },
      "package": "com.foodlog.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FoodLog to access your camera to photograph food for calorie tracking."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FoodLog to access your photo library to select food photos for tracking."
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "food-log"
      }
    }
  }
}
